# Per-directory clang-tidy overrides for the tests/ directory.
# Inherits all rules from the root .clang-tidy, then disables checks that
# produce unavoidable false-positives in doctest-based test code.
InheritParentConfig: true

Checks: >-
  -bugprone-empty-catch,
  -bugprone-exception-escape,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-throwing-static-initialization,
  -cert-err33-c,
  -cert-err58-cpp,
  -concurrency-mt-unsafe,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -hicpp-signed-bitwise,
  -llvm-use-ranges,
  -modernize-raw-string-literal,
  -readability-function-cognitive-complexity,
  -readability-identifier-naming,
  -readability-magic-numbers

# Rationale for each disabled check:
#
# bugprone-implicit-widening-of-multiplication-result:
#   Test helpers pass integer literals like 24 * 60 * 60 to int64_t parameters.
#   The products fit in int; widening on assignment is safe and conventional.
#
# bugprone-throwing-static-initialization / cert-err58-cpp:
#   TEST_SUITE-level helper variables (e.g. TextWidthCalculator) are shared
#   across TEST_CASEs and must be constructed at scope entry. The constructor
#   of std::function may throw in theory; in practice these are safe lambdas
#   and the pattern is idiomatic for doctest test fixtures.
#
# cert-err33-c:
#   doctest CHECK()/REQUIRE() macros expand to expressions whose return value
#   is intentionally discarded by the framework. Every assertion in every test
#   triggers this false-positive. Suppressing per-line is impractical.
#
# modernize-raw-string-literal:
#   Test cases intentionally use escaped string literals like "C:\\Users\\..."
#   to make the Windows-style paths easy to read and compare against expected
#   values. Raw string literals would not improve clarity here.
#
# readability-function-cognitive-complexity:
#   doctest TEST_CASE / TEST_SUITE macros generate anonymous functions that
#   aggregate many small assertions. The "complexity" is artificial scaffolding,
#   not actual code complexity.
#
# hicpp-signed-bitwise:
#   FILETIME epoch-conversion helpers perform bitwise AND/shift on int64_t
#   values (Windows 100-ns timestamp arithmetic). The operations are safe
#   and idiomatic; the signed type is dictated by the Windows API structs.
#
# readability-magic-numbers / cppcoreguidelines-avoid-magic-numbers:
#   Test assertions use concrete expected values (lengths, counts, IDs) that
#   are intentionally literal — naming them as constants would obscure intent.
#
# readability-identifier-naming:
#   Test infrastructure (fixtures, mocks) follows the same snake_case_ member
#   convention as production code. The identifier-naming check conflicts with
#   some test-specific patterns (e.g. mutable members in mock classes).
#
# bugprone-empty-catch:
#   Test helpers (e.g. SetEnvironmentVariable, SafeRemoveFile) intentionally
#   catch all exceptions to preserve noexcept or prevent test cleanup from
#   failing. Suppressing at directory level avoids NOLINT in every such block.
#
# bugprone-exception-escape:
#   Fixture destructors and teardown paths catch all exceptions and log; the
#   analyzer still flags possible throw paths through Logger/std::string. Test
#   code is not required to be fully no-throw in destructors when catch-all
#   is used for robustness.
#
# concurrency-mt-unsafe:
#   getenv/setenv/unsetenv are used only in test setup/teardown (e.g.
#   TestGeminiApiKeyFixture). Tests are single-threaded for these helpers.
#
# cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,
# cppcoreguidelines-pro-bounds-constant-array-index:
#   Test data builders and helpers use guarded indices (e.g. i % 7 for fixed
#   arrays, loop bounds). Using .at() or range-for everywhere would add noise
#   in test code with little benefit.
#
# llvm-use-ranges:
#   Project targets C++17; the check suggests std::ranges algorithms (C++20).
#   Disabling in tests avoids NOLINT on every loop that could be a range algo.
